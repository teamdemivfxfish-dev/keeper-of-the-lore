# Copy this file to ".env" and fill in the values.

# --- Required ---
# Bot token from the Discord Developer Portal (Bot tab > Reset Token).
DISCORD_TOKEN=your-discord-bot-token-here
# Google AI Studio API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# --- Moderation (directive b). Leave MOD_CHANNELS empty to run Q&A only. ---
# Comma-separated channel IDs to watch for canon-breaking messages.
# In Discord: User Settings > Advanced > Developer Mode ON, then right-click a
# channel > Copy Channel ID.
MOD_CHANNELS=

# --- Optional tuning ---
# Q&A model. Bump to gemini-2.5-pro for sharper reasoning on hard questions.
MODEL=gemini-2.5-flash
# Moderation model. Runs on (almost) every message in watched channels. Keep
# this on a Flash model (gemini-2.5-pro cannot disable thinking).
MOD_MODEL=gemini-2.5-flash
# Minimum confidence to correct a message: low | medium | high | certain.
# Higher = quieter bot. "high" is a good default.
MOD_MIN_CONFIDENCE=high
# Ignore messages shorter than this many characters.
MOD_MIN_LENGTH=25

# Server (guild) ID for INSTANT slash-command sync. Empty = global sync (new
# commands can take up to ~1h to show). The bot prints your server's ID at startup.
# Comma-separate for multiple servers.
GUILD_ID=

# --- Gemini key rotation + local fallback ---
# Extra Gemini keys to rotate through on quota/rate-limit errors BEFORE falling
# back to local. Comma-separated. NOTE: rotation only buys real headroom if the
# keys are on SEPARATE Google projects/accounts; keys under one project share the
# same daily quota, so rotating them does nothing.
GEMINI_API_KEYS=
# Local model served by Ollama, used automatically when Gemini is unavailable.
# Must be pulled first (e.g. `ollama pull gemma4:latest`).
OLLAMA_MODEL=gemma4:latest
# Embedding model for retrieval (RAG). Pull with `ollama pull nomic-embed-text`.
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://localhost:11434
# How many lore passages to feed the local model per question (RAG breadth).
RAG_TOP_K=8
# Context window for the local model. Keep modest; RAG keeps the prompt small.
OLLAMA_NUM_CTX=8192
